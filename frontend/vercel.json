{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/portfolio-frontend",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-domain.onrender.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

